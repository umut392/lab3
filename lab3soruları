#include <iostream>

using namespace std;
int* createArray(int size) {
    cout<<"enter numbers to fill array"<<endl;
    int* p;
    p=new int [size];
    for (int i = 0; i < size; i++) {
        cin>>p[i];
    }

    return p;



}
void swapValues(int* p1, int* p2) {
    cout<<"Swapping two numbers"<<endl;
    cout<<"Before swap"<<endl;
    cout <<"a "<< *p1<< endl;
    cout<<"b "<< *p2<<endl;
    cout<<"After swap"<<endl;
    int* pointer=p1;
    p1=p2;
    p2=pointer;

    cout <<"a "<< *p1<< endl;
    cout<<"b "<< *p2<<endl;
    cout<<"---------------------"<<endl;
}
void printArray(int* arr, int size) {


    cout<<"Array elements:"<<endl;

    for (int i = 0; i < size; i++) {
        cout<<arr[i]<<" ";
    }
    cout<<endl;
    cout<<endl;
    cout<<"---------------------"<<endl;

}
int findSum(int* arr, int size) {
    int sum=0;
    for (int i = 0; i < size; i++) {
        sum+=arr[i];
    }
    cout<<"Sum of elements: "<<sum<<endl;
    cout<<"---------------------"<<endl;
    return sum;
}
void deleteArray(int* arr) {
    cout<<"Deleting array..."<<endl;
    cout<<"Memory released successfully.";
    delete[] arr;
    cout<<"---------------------"<<endl;
}
void shiftRight(int* arr, int size) {
    cout<<"Shifting array to the right..."<<endl;
    cout<<"Array after shiftRight:"<<endl;

    cout<<endl;
    int last=size;
   for (int i=size;i>0;i--) {
       arr[i]=arr[i-1];
   }
    arr[0]=last;




    for (int i=0;i<size;i++) {
        cout<<arr[i]<<" ";
    }
    cout<<endl;
    cout<<"---------------------"<<endl;
}


int main() {
    cout<<"enter array size"<<endl;
    int size;
    cin>>size;







    int* arraypointer=createArray(size);
    printArray(arraypointer,size);
    findSum(arraypointer,size);
    shiftRight(arraypointer,size);






}



